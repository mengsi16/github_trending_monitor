# Anthropic / MiniMax
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic

# GitHub (可选)
GITHUB_TOKEN=ghp_xxx

# 飞书
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=your_app_secret_here
FEISHU_BOT_OPEN_ID=oc_xxx
FEISHU_ENCRYPT_KEY=

# 飞书 Webhook 服务器配置（用于接收消息）
# 需要在飞书开放平台配置事件订阅 URL 指向此地址
FEISHU_WEBHOOK_HOST=0.0.0.0
FEISHU_WEBHOOK_PORT=8080
FEISHU_WEBHOOK_PATH=/webhook/feishu

# 飞书长连接（WebSocket）心跳/重连调优
# 症状: 日志出现 "receive message loop exit, err: no close frame received or sent"
# 原因: SDK 默认 ping_interval=120s，在 NAT/公司防火墙/VPN 下空闲 TCP 连接会被静默回收。
#       缩短 ping 间隔可以主动喂 NAT，显著减少断线。
# FEISHU_WS_PING_INTERVAL  客户端主动 ping 间隔（秒），建议 15-45，默认 30
# FEISHU_WS_RECONNECT_INTERVAL  断线后的重连间隔（秒），SDK 默认 120，默认改为 10 更快恢复
FEISHU_WS_PING_INTERVAL=30
FEISHU_WS_RECONNECT_INTERVAL=10

# 邮件 (SMTP 发送)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM=your_email@gmail.com

# 邮件 (IMAP 接收) - 用于接收邮件请求
# Gmail 需要先启用 IMAP: https://mail.google.com/settings/lesssecureapps
# 然后生成应用专用密码: https://myaccount.google.com/signinoptions/two-step-verification
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your_email@gmail.com
IMAP_PASSWORD=your_app_password_here

# brain-base 知识底座（可选）
# 指向已 clone 的 brain-base 仓库根目录；未设置则 QA/Summarizer/Crawler 自动降级到 ChromaDB
# Windows 示例:  BRAIN_BASE_PATH=E:\PostGraduate\Project\plan-for-all\brain-base
# Linux/macOS:   BRAIN_BASE_PATH=/absolute/path/to/brain-base
# 注意：改动此变量后需要重启进程生效（模块级缓存）
BRAIN_BASE_PATH=
