# Anthropic / MiniMax
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic

# GitHub (可选)
GITHUB_TOKEN=ghp_xxx

# 飞书
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=your_app_secret_here
FEISHU_BOT_OPEN_ID=oc_xxx
FEISHU_ENCRYPT_KEY=

# 飞书 Webhook 服务器配置（用于接收消息）
# 需要在飞书开放平台配置事件订阅 URL 指向此地址
FEISHU_WEBHOOK_HOST=0.0.0.0
FEISHU_WEBHOOK_PORT=8080
FEISHU_WEBHOOK_PATH=/webhook/feishu

# 邮件 (SMTP 发送)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM=your_email@gmail.com

# 邮件 (IMAP 接收) - 用于接收邮件请求
# Gmail 需要先启用 IMAP: https://mail.google.com/settings/lesssecureapps
# 然后生成应用专用密码: https://myaccount.google.com/signinoptions/two-step-verification
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your_email@gmail.com
IMAP_PASSWORD=your_app_password_here
